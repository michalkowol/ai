#!/bin/bash

set -e

TOOL="bash"
DIR=""

while [ $# -gt 0 ]; do
    case "$1" in
        --claude)
            TOOL="claude"
            shift
            ;;
        --cursor)
            TOOL="cursor"
            shift
            ;;
        --bash)
            TOOL="bash"
            shift
            ;;
        --*)
            echo "Unknown option: $1" >&2
            echo "Usage: ai [--claude|--cursor|--bash] [path]" >&2
            exit 1
            ;;
        *)
            if [ -n "$DIR" ]; then
                echo "Unexpected argument: $1" >&2
                echo "Usage: ai [--claude|--cursor|--bash] [path]" >&2
                exit 1
            fi
            DIR="$1"
            shift
            ;;
    esac
done

DIR="${DIR:-.}"
WORKTREE_DIR="$(realpath "$DIR")"

if [ ! -d "$WORKTREE_DIR" ]; then
    echo "Error: Directory '$WORKTREE_DIR' does not exist!" >&2
    exit 1
fi

EXTRA_MOUNTS=()
if [ -f "$WORKTREE_DIR/.git" ]; then
    GIT_COMMON_DIR="$(cd "$WORKTREE_DIR" && git rev-parse --git-common-dir 2>/dev/null || true)"
    if [ -n "$GIT_COMMON_DIR" ]; then
        case "$GIT_COMMON_DIR" in
            /*) ;;
            *) GIT_COMMON_DIR="$WORKTREE_DIR/$GIT_COMMON_DIR" ;;
        esac
        GIT_COMMON_DIR="$(realpath "$GIT_COMMON_DIR")"
        EXTRA_MOUNTS+=(-v "$GIT_COMMON_DIR:$GIT_COMMON_DIR")
    fi
fi

AI_DIR=~/dev/ai
cd "$AI_DIR"

docker build -q -t ai . > /dev/null

CLAUDE_MOUNTS=(
    -v "$AI_DIR/claude/.claude:/home/ubuntu/.claude"
    -v "$AI_DIR/claude/.claude.json:/home/ubuntu/.claude.json"
    -v "$AI_DIR/common/commands:/home/ubuntu/.claude/commands"
    -v "$AI_DIR/common/skills:/home/ubuntu/.claude/skills"
    -v "$AI_DIR/common/rules:/home/ubuntu/.claude/rules"
    -v "$AI_DIR/common/mcp.json:/workspace/.mcp.json"
)

CURSOR_MOUNTS=(
    -v "$AI_DIR/cursor/.cursor:/home/ubuntu/.cursor"
    -v "$AI_DIR/cursor/.config/cursor:/home/ubuntu/.config/cursor"
    -v "$AI_DIR/common/commands:/home/ubuntu/.cursor/commands"
    -v "$AI_DIR/common/skills:/home/ubuntu/.cursor/skills"
    -v "$AI_DIR/common/rules:/home/ubuntu/.cursor/rules"
    -v "$AI_DIR/common/mcp.json:/home/ubuntu/.cursor/mcp.json"
)

case "$TOOL" in
    claude) CMD=("claude" "--dangerously-skip-permissions") ;;
    cursor) CMD=("cursor-agent" "--force") ;;
    bash)   CMD=("bash") ;;
esac

DOCKER_SOCK_GID=$(docker run --rm -v /var/run/docker.sock:/var/run/docker.sock ai stat -c '%g' /var/run/docker.sock)

docker run -it \
    -v /var/run/docker.sock:/var/run/docker.sock \
    --group-add "$DOCKER_SOCK_GID" \
    --add-host=host.docker.internal:host-gateway \
    -v "$HOME/.gradle:/home/ubuntu/.gradle" \
    -v "$HOME/.m2:/home/ubuntu/.m2" \
    -v "$WORKTREE_DIR:/workspace" \
    "${CLAUDE_MOUNTS[@]}" \
    "${CURSOR_MOUNTS[@]}" \
    "${EXTRA_MOUNTS[@]}" \
    ai "${CMD[@]}"
