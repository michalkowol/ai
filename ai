#!/bin/bash

set -e

TOOL="claude"
DIR=""
IMAGE_KIND="java"
IMAGE_VERSION="25"
RESUME=""
UPDATE=""

USAGE="Usage: ai [--claude|--cursor|--bash] [--java <version>|--node <version>] [--resume <session-id>] [--update] [path]"

while [ $# -gt 0 ]; do
    case "$1" in
        --claude)
            TOOL="claude"
            shift
            ;;
        --cursor)
            TOOL="cursor"
            shift
            ;;
        --bash)
            TOOL="bash"
            shift
            ;;
        --java)
            if [ -z "$2" ]; then
                echo "Error: --java requires a version argument" >&2
                exit 1
            fi
            IMAGE_KIND="java"
            IMAGE_VERSION="$2"
            shift 2
            ;;
        --java=*)
            IMAGE_KIND="java"
            IMAGE_VERSION="${1#--java=}"
            shift
            ;;
        --node)
            if [ -z "$2" ]; then
                echo "Error: --node requires a version argument" >&2
                exit 1
            fi
            IMAGE_KIND="node"
            IMAGE_VERSION="$2"
            shift 2
            ;;
        --node=*)
            IMAGE_KIND="node"
            IMAGE_VERSION="${1#--node=}"
            shift
            ;;
        --resume)
            if [ -z "$2" ]; then
                echo "Error: --resume requires a session id argument" >&2
                exit 1
            fi
            RESUME="$2"
            shift 2
            ;;
        --resume=*)
            RESUME="${1#--resume=}"
            shift
            ;;
        --update)
            UPDATE="1"
            shift
            ;;
        --*)
            echo "Unknown option: $1" >&2
            echo "$USAGE" >&2
            exit 1
            ;;
        *)
            if [ -n "$DIR" ]; then
                echo "Unexpected argument: $1" >&2
                echo "$USAGE" >&2
                exit 1
            fi
            DIR="$1"
            shift
            ;;
    esac
done

DIR="${DIR:-.}"
WORKTREE_DIR="$(realpath "$DIR")"

if [ ! -d "$WORKTREE_DIR" ]; then
    echo "Error: Directory '$WORKTREE_DIR' does not exist!" >&2
    exit 1
fi

GIT_ENV=()
HOST_GIT_NAME="${GIT_AUTHOR_NAME:-$(git -C "$WORKTREE_DIR" config user.name 2>/dev/null || true)}"
HOST_GIT_EMAIL="${GIT_AUTHOR_EMAIL:-$(git -C "$WORKTREE_DIR" config user.email 2>/dev/null || true)}"
HOST_COMMIT_EMAIL="${GIT_COMMITTER_EMAIL:-$HOST_GIT_EMAIL}"
if [ -n "$HOST_GIT_NAME" ]; then
    GIT_ENV+=(-e "GIT_AUTHOR_NAME=$HOST_GIT_NAME")
fi
if [ -n "$HOST_GIT_EMAIL" ]; then
    GIT_ENV+=(-e "GIT_AUTHOR_EMAIL=$HOST_GIT_EMAIL")
fi
if [ -n "$HOST_COMMIT_EMAIL" ]; then
    GIT_ENV+=(-e "GIT_COMMITTER_EMAIL=$HOST_COMMIT_EMAIL")
fi

EXTRA_MOUNTS=()
if [ -f "$WORKTREE_DIR/.git" ]; then
    GIT_COMMON_DIR="$(cd "$WORKTREE_DIR" && git rev-parse --git-common-dir 2>/dev/null || true)"
    if [ -n "$GIT_COMMON_DIR" ]; then
        case "$GIT_COMMON_DIR" in
            /*) ;;
            *) GIT_COMMON_DIR="$WORKTREE_DIR/$GIT_COMMON_DIR" ;;
        esac
        GIT_COMMON_DIR="$(realpath "$GIT_COMMON_DIR")"
        EXTRA_MOUNTS+=(-v "$GIT_COMMON_DIR:$GIT_COMMON_DIR")
    fi
fi

AI_DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
cd "$AI_DIR"

case "$IMAGE_KIND" in
    java) BASE_IMAGE="eclipse-temurin:${IMAGE_VERSION}" ;;
    node) BASE_IMAGE="node:${IMAGE_VERSION}" ;;
esac

IMAGE_TAG="ai:${IMAGE_KIND}${IMAGE_VERSION}"

if [ -n "$UPDATE" ]; then
    docker build -t "$IMAGE_TAG" --build-arg "BASE_IMAGE=${BASE_IMAGE}" --pull --no-cache .
else
    docker build -q -t "$IMAGE_TAG" --build-arg "BASE_IMAGE=${BASE_IMAGE}" . > /dev/null
fi

CLAUDE_MOUNTS=(
    -v "$AI_DIR/claude/.claude:/home/ubuntu/.claude"
    -v "$AI_DIR/claude/.claude.json:/home/ubuntu/.claude.json"
    -v "$AI_DIR/common/commands:/home/ubuntu/.claude/commands"
    -v "$AI_DIR/common/skills:/home/ubuntu/.claude/skills"
    -v "$AI_DIR/common/rules:/home/ubuntu/.claude/rules"
)

CURSOR_MOUNTS=(
    -v "$AI_DIR/cursor/.cursor:/home/ubuntu/.cursor"
    -v "$AI_DIR/cursor/.config/cursor:/home/ubuntu/.config/cursor"
    -v "$AI_DIR/common/commands:/home/ubuntu/.cursor/commands"
    -v "$AI_DIR/common/skills:/home/ubuntu/.cursor/skills"
    -v "$AI_DIR/common/rules:/home/ubuntu/.cursor/rules"
)

case "$TOOL" in
    claude) CMD=("claude" "--dangerously-skip-permissions") ;;
    cursor) CMD=("cursor-agent" "--force") ;;
    bash)   CMD=("bash") ;;
esac

if [ -n "$RESUME" ]; then
    case "$TOOL" in
        claude|cursor) CMD+=("--resume" "$RESUME") ;;
        *)
            echo "Error: --resume is only supported with --claude or --cursor" >&2
            exit 1
            ;;
    esac
fi

DOCKER_SOCK_GID=$(docker run --rm -v /var/run/docker.sock:/var/run/docker.sock "$IMAGE_TAG" stat -c '%g' /var/run/docker.sock)

docker run -it --rm \
    -v /var/run/docker.sock:/var/run/docker.sock \
    --group-add "$DOCKER_SOCK_GID" \
    --add-host=host.docker.internal:host-gateway \
    -v "$HOME/.gradle:/home/ubuntu/.gradle-ro:ro" \
    -e GRADLE_RO_DEP_CACHE=/home/ubuntu/.gradle-ro/caches \
    -v "$HOME/.m2:/home/ubuntu/.m2" \
    "${GIT_ENV[@]}" \
    -v "$WORKTREE_DIR:/workspace" \
    "${CLAUDE_MOUNTS[@]}" \
    "${CURSOR_MOUNTS[@]}" \
    "${EXTRA_MOUNTS[@]}" \
    "$IMAGE_TAG" "${CMD[@]}"
